library(readr)
library(ggplot2)
plastic.trend <- read_csv("R/working/AlbatrossPlasticsTrend.csv", 
col_types = cols(species = col_factor(levels = c("LAAL", "BFAL"))))
View(plastic.trend)

# 1) Linear regression of BFAL_FO and LAAL_FO as a function of year

by(plastic.trend$FO, plastic.trend$species, shapiro.test)
# Test the BFAL_FO data for normality
# normally distributed (W = 0.95767, p-value = 0.7737)
# Test the LAAL_FO data for normality
# normally distributed (W = 0.88231, p-value = 0.166)


# Perform linear regression using aov (analysis of variance) command
# Ancova model includes two predictors (species and year)
# and tests for the species*year interaction


trend.model <- aov (plastic.trend$FO ~ plastic.trend$species * plastic.trend$year)

# extract MS terms and p values
summary(trend.model)
# extract R-squared values
summary.lm(trend.model)

#Extract residuals to test aov assumptions

# i)  normality of residuals
shapiro.test(trend.model$residuals)
# normally distributed (W = 0.98319, p-value = 0.9769)

#ii) autocorrelation of residuals with Durbin-Watson (DW) test
library(lmtest)
dwtest(trend.model)
# assumption of residual autocorrelation met: DW = 2.287, p-value = 0.4288
# use ACF Plot to visualize residual autocorrelation
acf(trend.model$residuals)


#iii) testing homoskedasticity with # studentized Breusch-Pagan (BP) test
library(lmtest)
bptest(trend.model)
# assumption of equality of variances met: 
# studentized Breusch-Pagan test: BP = 3.4403, df = 3, p-value = 0.3286


# iv) check leverage of data points with Cooks distance
leverage = cooks.distance(trend.model)
# use boxplot to visualize leverage
boxplot(leverage) # note: all values < 1

# Create the regression plot with ggplot2
# Formula: FO(DV) ~ species (IV) * year (IV)
# species and year are the two interacting independent variables (IVs)

FO_reg_plot <- ggplot(plastic.trend, aes(x = year, y = FO, color = factor(species))) +
  scale_color_manual(values = c("BFAL" = "black", "LAAL" = "gray70")) +
  theme_classic() + xlab("Year") + ylab("Plastic Frequency of Occurrence (FO)")+
  geom_smooth(method = "lm", se = TRUE, fill = "lightgray", alpha = 0.25) +
  geom_point(shape = 16, size = 4)   +
  scale_y_continuous(breaks = c(30, 40, 50, 60, 70, 80, 90)) +
  coord_cartesian(ylim = c(28, 92)) +
  labs(color = "Species")

FO_reg_plot

