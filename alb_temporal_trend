# 2) Because there was a significant year * species interaction
# Follow up with paired t test of FO by species to account for the influence of year

# Calculate difference in species-specific plastic FO
# sp.diff.FO = LAAL.FO - BFAL.FO
# Test this difference for normality, before performing paired t test

# Example: Select only rows where 'group_variable' is equal to species
LAAL.data <- subset(plastic.trend, species == "LAAL")
BFAL.data <- subset(plastic.trend, species == "BFAL")
sp.diff.FO = LAAL.data$FO - BFAL.data$FO

boxplot(sp.diff.FO)
shapiro.test(sp.diff.FO)  
#normally distributed: W = 0.9309, p-value = 0.49

# Create a boxplot of the FO values, paired by year
library(ggplot2)
library(ggpubr)

# Perform paired t test
stat.test <- plastic.trend %>% 
  t_test(FO ~ species, paired = TRUE) %>%
  add_significance()
stat.test
# significant result: t = -4.56, df = 8, p = 0.00184

